{
  "schema": "SandboxPolicyV1",
  "runtime": "docker",
  "image": "node:22-alpine",
  "network": "none",
  "autoInstall": false,
  "autoStart": false,
  "autoPull": false,
  "hostWriteAllowed": false,
  "mountHome": false,
  "mountDockerSocket": false,
  "maxFiles": 5000,
  "maxFileBytes": 10485760,
  "maxTotalBytes": 104857600,
  "allowedCommands": [
    "node --test",
    "npm test",
    "npm run test",
    "npm run verify",
    "git diff --no-index",
    "true"
  ],
  "excludedNames": [
    ".git",
    "node_modules",
    ".env",
    ".ssh",
    ".codex",
    ".claude",
    ".tatwo-ultrawork-beta"
  ]
}
