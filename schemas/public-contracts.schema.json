{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tatwo.example/schemas/public-contracts.schema.json",
  "title": "TATWO-ULTRAWORK beta public contracts",
  "$defs": {
    "GoalContractV1": {
      "type": "object",
      "required": [
        "schema",
        "contractID",
        "goalHash",
        "outcome",
        "criteria",
        "projectPrinciples",
        "architectureAnchors",
        "protectedSurfaces",
        "revision"
      ],
      "properties": {
        "schema": { "const": "GoalContractV1" },
        "contractID": { "type": "string" },
        "goalHash": { "type": "string", "minLength": 64, "maxLength": 64 },
        "outcome": { "type": "string", "minLength": 1 },
        "criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "nonGoals": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "projectPrinciples": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "architectureAnchors": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "protectedSurfaces": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "revision": { "type": "integer", "minimum": 1 },
        "parentGoalHash": { "type": ["string", "null"] }
      }
    },
    "ContextArchitectureReceiptV1": {
      "type": "object",
      "required": ["schema", "currentTruth", "boundaries", "evidence", "sufficiency", "contextHash"],
      "properties": {
        "schema": { "const": "ContextArchitectureReceiptV1" },
        "currentTruth": { "type": "array", "items": { "type": "string" } },
        "actors": { "type": "array", "items": { "type": "string" } },
        "objects": { "type": "array", "items": { "type": "string" } },
        "boundaries": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "flows": { "type": "array", "items": { "type": "string" } },
        "contradictions": { "type": "array", "items": { "type": "string" } },
        "unresolvedUnknowns": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "sufficiency": { "enum": ["insufficient", "provisional", "sufficient", "stale"] },
        "contextHash": { "type": "string" }
      }
    },
    "PlanContractV1": {
      "type": "object",
      "required": ["schema", "planID", "goalHash", "contextHash", "planHash", "integrationClosure", "steps", "verification"],
      "properties": {
        "schema": { "const": "PlanContractV1" },
        "planID": { "type": "string" },
        "goalHash": { "type": "string" },
        "contextHash": { "type": "string" },
        "planHash": { "type": "string" },
        "integrationClosure": { "type": "string" },
        "steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "verification": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "LoopTaskV1": {
      "type": "object",
      "required": ["schema", "loopID", "contractID", "goalHash", "planHash", "title", "objective", "identity", "status"],
      "properties": {
        "schema": { "const": "LoopTaskV1" },
        "loopID": { "type": "string" },
        "contractID": { "type": "string" },
        "goalHash": { "type": "string" },
        "planHash": { "type": "string" },
        "title": { "type": "string" },
        "objective": { "type": "string" },
        "identity": { "type": "string" },
        "status": { "enum": ["issued", "passed", "blocked", "human_gate", "stale"] }
      }
    },
    "GoalAlignmentReceiptV1": {
      "type": "object",
      "required": ["schema", "receiptID", "loopID", "goalHash", "planHash", "status", "submittedBy"],
      "properties": {
        "schema": { "const": "GoalAlignmentReceiptV1" },
        "status": { "enum": ["aligned", "diverged", "blocked"] },
        "submittedBy": { "type": "string" }
      }
    },
    "GoalJudgeReceiptV1": {
      "type": "object",
      "required": ["schema", "contractID", "goalHash", "passed", "missingCriteria", "loopOutcomes", "decision", "judgedBy"],
      "properties": {
        "schema": { "const": "GoalJudgeReceiptV1" },
        "passed": { "type": "boolean" },
        "judgedBy": { "type": "string" },
        "decision": { "enum": ["passed", "replan_or_rollback"] }
      }
    },
    "AdapterManifestV1": {
      "type": "object",
      "required": ["id", "type", "enabled"],
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["command", "http"] },
        "enabled": { "type": "boolean" }
      }
    },
    "SandboxPolicyV1": {
      "type": "object",
      "required": ["schema", "runtime", "network", "autoInstall", "autoPull", "hostWriteAllowed", "allowedCommands"],
      "properties": {
        "schema": { "const": "SandboxPolicyV1" },
        "runtime": { "const": "docker" },
        "network": { "const": "none" },
        "autoInstall": { "const": false },
        "autoPull": { "const": false },
        "hostWriteAllowed": { "const": false },
        "allowedCommands": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
